# Supabase Configuration (Public)
# These keys are public and can be exposed in the frontend.
# Obtain from: https://app.supabase.com/project/{project}/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://REDACTED_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REDACTED_ANON_KEY

# Supabase Configuration (Private)
# Used for server-side operations and administrative tasks.
# Must be kept secret and never exposed in frontend code.
# Obtain from: https://app.supabase.com/project/{project}/settings/api
SUPABASE_SERVICE_ROLE_KEY=

# Local Development (Optional)
# For local Supabase development with `npm run supabase:start`
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
